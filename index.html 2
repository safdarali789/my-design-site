<!DOCTYPE html>
<html lang="ur">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>سوشل میڈیا پوسٹ کریٹر | Social Media Post Creator</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 10px;
            color: #333;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        .header {
            text-align: center;
            color: white;
            margin-bottom: 20px;
        }
        .header h1 {
            font-size: 28px;
            margin-bottom: 5px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        .header p {
            font-size: 14px;
            opacity: 0.9;
        }
        .main-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
        }
        @media (max-width: 768px) {
            .main-content {
                grid-template-columns: 1fr;
            }
        }
        .panel {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.15);
            overflow-y: auto;
            max-height: 800px;
        }
        .preview-section {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 600px;
            background: #f5f5f5;
            border-radius: 12px;
            position: relative;
        }
        canvas {
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            cursor: crosshair;
            max-width: 100%;
        }
        .section-title {
            font-size: 14px;
            font-weight: 600;
            color: #667eea;
            margin: 15px 0 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .template-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
            margin-bottom: 15px;
        }
        .template-btn {
            padding: 10px;
            border: 2px solid #ddd;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            font-size: 12px;
            font-weight: 500;
            transition: all 0.3s;
            text-align: center;
        }
        .template-btn:hover {
            border-color: #667eea;
            background: #f0f4ff;
        }
        .template-btn.active {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }
        .control-group {
            margin-bottom: 15px;
        }
        .control-group label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 6px;
            color: #555;
        }
        input[type="text"],
        input[type="color"],
        input[type="number"],
        input[type="file"],
        textarea,
        select {
            width: 100%;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 12px;
            font-family: inherit;
            transition: border-color 0.3s;
        }
        textarea {
            resize: vertical;
            min-height: 60px;
            font-size: 12px;
        }
        input[type="text"]:focus,
        textarea:focus,
        select:focus,
        input[type="color"]:focus {
            border-color: #667eea;
            outline: none;
            box-shadow: 0 0 0 2px rgba(102, 126, 234, 0.1);
        }
        .color-picker-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }
        .color-input {
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .color-input input[type="color"] {
            width: 50px;
            height: 36px;
            cursor: pointer;
        }
        .slider-group {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 10px;
            align-items: center;
        }
        input[type="range"] {
            width: 100%;
            height: 6px;
            border-radius: 3px;
            background: #ddd;
            outline: none;
            -webkit-appearance: none;
        }
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #667eea;
            cursor: pointer;
        }
        input[type="range"]::-moz-range-thumb {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #667eea;
            cursor: pointer;
            border: none;
        }
        .button-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 20px;
        }
        button {
            padding: 10px 16px;
            border: none;
            border-radius: 6px;
            font-weight: 500;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-primary {
            background: #667eea;
            color: white;
        }
        .btn-primary:hover {
            background: #5568d3;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }
        .btn-secondary {
            background: #f0f0f0;
            color: #333;
        }
        .btn-secondary:hover {
            background: #e0e0e0;
        }
        .btn-danger {
            background: #ff6b6b;
            color: white;
        }
        .btn-danger:hover {
            background: #ff5252;
        }
        .font-selector {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
        }
        .font-option {
            padding: 6px;
            border: 1px solid #ddd;
            border-radius: 4px;
            text-align: center;
            cursor: pointer;
            font-size: 11px;
            transition: all 0.2s;
        }
        .font-option:hover {
            border-color: #667eea;
        }
        .font-option.selected {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }
        .shape-tools {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }
        .shape-btn {
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 4px;
            background: white;
            cursor: pointer;
            font-size: 11px;
            transition: all 0.2s;
        }
        .shape-btn:hover {
            background: #f0f4ff;
            border-color: #667eea;
        }
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
            border-bottom: 1px solid #ddd;
        }
        .tab {
            padding: 10px 15px;
            border: none;
            background: none;
            cursor: pointer;
            font-weight: 500;
            font-size: 12px;
            border-bottom: 2px solid transparent;
            color: #999;
            transition: all 0.3s;
        }
        .tab.active {
            color: #667eea;
            border-bottom-color: #667eea;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        .effects-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }
        .effect-item {
            padding: 8px;
            background: #f5f5f5;
            border-radius: 4px;
            cursor: pointer;
            text-align: center;
            font-size: 11px;
            transition: all 0.2s;
        }
        .effect-item:hover {
            background: #e8f0ff;
        }
        .status-bar {
            background: white;
            padding: 15px;
            border-radius: 12px;
            text-align: center;
            font-size: 13px;
            color: #666;
            margin-bottom: 10px;
        }
        .loader {
            display: inline-block;
            width: 12px;
            height: 12px;
            border: 2px solid #f3f3f3;
            border-top: 2px solid #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>✨ سوشل میڈیا پوسٹ کریٹر</h1>
            <p>Professional Social Media Post Designer</p>
        </div>

        <div class="main-content">
            <!-- Control Panel -->
            <div class="panel">
                <div class="tabs">
                    <button class="tab active" onclick="switchTab('templates')">ٹمپلیس</button>
                    <button class="tab" onclick="switchTab('text')">ٹیکسٹ</button>
                    <button class="tab" onclick="switchTab('design')">ڈیزائن</button>
                    <button class="tab" onclick="switchTab('effects')">اثرات</button>
                </div>

                <!-- Templates Tab -->
                <div id="templates" class="tab-content active">
                    <div class="section-title">سوشل میڈیا ٹمپلیس</div>
                    <div class="template-grid">
                        <button class="template-btn active" onclick="selectTemplate(1080, 1350, 'Instagram Story')">📱 Instagram<br>Story</button>
                        <button class="template-btn" onclick="selectTemplate(1080, 1080, 'Instagram Post')">📸 Instagram<br>Post</button>
                        <button class="template-btn" onclick="selectTemplate(1200, 628, 'Facebook')">👍 Facebook<br>Cover</button>
                        <button class="template-btn" onclick="selectTemplate(1024, 512, 'Twitter/X')">𝕏 Twitter/X<br>Header</button>
                        <button class="template-btn" onclick="selectTemplate(1200, 1500, 'Pinterest')">📌 Pinterest<br>Pin</button>
                        <button class="template-btn" onclick="selectTemplate(1280, 720, 'YouTube')">▶️ YouTube<br>Thumbnail</button>
                        <button class="template-btn" onclick="selectTemplate(1080, 1920, 'TikTok')">🎵 TikTok<br>Video</button>
                        <button class="template-btn" onclick="selectTemplate(800, 600, 'Custom')">⚙️ Custom<br>Size</button>
                    </div>
                </div>

                <!-- Text Tab -->
                <div id="text" class="tab-content">
                    <div class="control-group">
                        <label>عنوان (Title)</label>
                        <input type="text" id="titleInput" placeholder="اپنا ہیڈنگ لکھیں / Write your heading" 
                               value="Your Amazing Title" onchange="updateCanvas()" oninput="updateCanvas()">
                    </div>
                    <div class="slider-group">
                        <label>سائز: <span id="titleSizeValue">48</span>px</label>
                        <input type="range" id="titleSize" min="20" max="80" value="48" onchange="updateCanvas()">
                    </div>
                    <div class="color-input">
                        <label style="flex: 1;">عنوان رنگ</label>
                        <input type="color" id="titleColor" value="#ffffff" onchange="updateCanvas()">
                    </div>

                    <div class="control-group" style="margin-top: 15px;">
                        <label>تفصیل (Description)</label>
                        <textarea id="descInput" placeholder="اپنا پیغام لکھیں / Write your message" 
                                  onchange="updateCanvas()" oninput="updateCanvas()">Add your description here for more impact and engagement!</textarea>
                    </div>
                    <div class="slider-group">
                        <label>سائز: <span id="descSizeValue">20</span>px</label>
                        <input type="range" id="descSize" min="12" max="40" value="20" onchange="updateCanvas()">
                    </div>
                    <div class="color-input">
                        <label style="flex: 1;">تفصیل رنگ</label>
                        <input type="color" id="descColor" value="#ffffff" onchange="updateCanvas()">
                    </div>

                    <div class="control-group" style="margin-top: 15px;">
                        <label>فونٹ فیملی (Font Family)</label>
                        <div class="font-selector">
                            <div class="font-option selected" style="font-family: Arial;" onclick="changeFontFamily('Arial')">Arial</div>
                            <div class="font-option" style="font-family: Georgia;" onclick="changeFontFamily('Georgia')">Georgia</div>
                            <div class="font-option" style="font-family: Courier;" onclick="changeFontFamily('Courier')">Courier</div>
                            <div class="font-option" style="font-family: Impact;" onclick="changeFontFamily('Impact')">Impact</div>
                            <div class="font-option" style="font-family: Comic Sans MS;" onclick="changeFontFamily('Comic Sans MS')">Comic</div>
                            <div class="font-option" style="font-family: Verdana;" onclick="changeFontFamily('Verdana')">Verdana</div>
                        </div>
                    </div>
                </div>

                <!-- Design Tab -->
                <div id="design" class="tab-content">
                    <div class="section-title">پس منظر (Background)</div>
                    
                    <div class="control-group">
                        <label>بیک گراؤنڈ رنگ</label>
                        <input type="color" id="bgColor" value="#667eea" onchange="updateCanvas()">
                    </div>

                    <div class="control-group">
                        <label>یا تصویر اپ لوڈ کریں</label>
                        <input type="file" id="bgImage" accept="image/*" onchange="loadBackgroundImage()">
                    </div>

                    <div class="control-group">
                        <label>گریڈیئنٹ اسٹائل</label>
                        <select id="gradientType" onchange="updateCanvas()">
                            <option value="none">کوئی نہیں</option>
                            <option value="linear-h">لیٹرل (بائیں سے دائیں)</option>
                            <option value="linear-v">عمودی (اوپر سے نیچے)</option>
                            <option value="diagonal">ڈائیگونل</option>
                            <option value="radial">سرکلر</option>
                        </select>
                    </div>

                    <div class="control-group">
                        <label>گریڈیئنٹ رنگ 1</label>
                        <input type="color" id="gradColor1" value="#667eea" onchange="updateCanvas()">
                    </div>

                    <div class="control-group">
                        <label>گریڈیئنٹ رنگ 2</label>
                        <input type="color" id="gradColor2" value="#764ba2" onchange="updateCanvas()">
                    </div>

                    <div class="section-title" style="margin-top: 20px;">شیپس اور عناصر</div>
                    <div class="shape-tools">
                        <button class="shape-btn" onclick="addShape('rect')">▭ مربع</button>
                        <button class="shape-btn" onclick="addShape('circle')">● دائرہ</button>
                        <button class="shape-btn" onclick="addShape('triangle')">▲ مثلث</button>
                        <button class="shape-btn" onclick="addShape('line')">━ لائن</button>
                    </div>

                    <div class="control-group" style="margin-top: 15px;">
                        <label>شیپ کا رنگ</label>
                        <input type="color" id="shapeColor" value="#ffffff" onchange="updateCanvas()">
                    </div>

                    <div class="section-title" style="margin-top: 20px;">سایہ اور بوردر</div>
                    <div class="control-group">
                        <label>سایہ شامل کریں</label>
                        <input type="checkbox" id="shadowToggle" onchange="updateCanvas()" style="width: 16px;">
                    </div>

                    <div class="control-group">
                        <label>بوردر شامل کریں</label>
                        <input type="checkbox" id="borderToggle" onchange="updateCanvas()" style="width: 16px;">
                    </div>
                </div>

                <!-- Effects Tab -->
                <div id="effects" class="tab-content">
                    <div class="section-title">متن کے اثرات</div>
                    <div class="effects-grid">
                        <div class="effect-item" onclick="applyEffect('bold')">🔤 Bold</div>
                        <div class="effect-item" onclick="applyEffect('italic')">𝘐 Italic</div>
                        <div class="effect-item" onclick="applyEffect('outline')">⊕ Outline</div>
                        <div class="effect-item" onclick="applyEffect('shadow')">⬡ Shadow</div>
                        <div class="effect-item" onclick="applyEffect('neon')">💫 Neon</div>
                        <div class="effect-item" onclick="applyEffect('3d')">3️⃣ 3D Effect</div>
                    </div>

                    <div class="section-title" style="margin-top: 20px;">منتخب شدہ اثرات</div>
                    <div id="effectsList" style="font-size: 12px; color: #666; padding: 10px; background: #f5f5f5; border-radius: 6px;">
                        کوئی اثر منتخب نہیں
                    </div>

                    <div class="section-title" style="margin-top: 20px;">فلٹرز</div>
                    <div class="slider-group">
                        <label>روشنی: <span id="brightnessValue">100</span>%</label>
                        <input type="range" id="brightness" min="50" max="150" value="100" onchange="updateCanvas()">
                    </div>
                    <div class="slider-group">
                        <label>سنترتا: <span id="contrastValue">100</span>%</label>
                        <input type="range" id="contrast" min="50" max="150" value="100" onchange="updateCanvas()">
                    </div>
                    <div class="slider-group">
                        <label>بہتری: <span id="saturationValue">100</span>%</label>
                        <input type="range" id="saturation" min="0" max="200" value="100" onchange="updateCanvas()">
                    </div>
                </div>

                <!-- Download Section -->
                <div class="button-group" style="margin-top: 20px;">
                    <button class="btn-primary" onclick="downloadImage()">⬇️ ڈاؤن لوڈ</button>
                    <button class="btn-secondary" onclick="resetDesign()">↺ دوبارہ شروع</button>
                </div>
            </div>

            <!-- Preview Section -->
            <div class="preview-section">
                <canvas id="canvas" width="1080" height="1350"></canvas>
            </div>
        </div>

        <div class="status-bar" id="statusBar">تیار ہے | Ready to create amazing posts! 🎨</div>
    </div>

    <script>
        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d');
        let currentFont = 'Arial';
        let activeEffects = [];
        let backgroundImage = null;

        const templateSizes = {
            'Instagram Story': { w: 1080, h: 1350 },
            'Instagram Post': { w: 1080, h: 1080 },
            'Facebook': { w: 1200, h: 628 },
            'Twitter/X': { w: 1024, h: 512 },
            'Pinterest': { w: 1200, h: 1500 },
            'YouTube': { w: 1280, h: 720 },
            'TikTok': { w: 1080, h: 1920 }
        };

        function selectTemplate(width, height, name) {
            canvas.width = width;
            canvas.height = height;
            
            document.querySelectorAll('.template-btn').forEach(btn => btn.classList.remove('active'));
            event.target.closest('.template-btn').classList.add('active');
            
            updateCanvas();
            showStatus(`${name} منتخب کیا گیا | Template selected: ${name}`);
        }

        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
            document.getElementById(tabName).classList.add('active');
            event.target.classList.add('active');
        }

        function updateCanvas() {
            const width = canvas.width;
            const height = canvas.height;
            const bgColor = document.getElementById('bgColor').value;
            const titleText = document.getElementById('titleInput').value;
            const descText = document.getElementById('descInput').value;
            const titleSize = parseInt(document.getElementById('titleSize').value);
            const descSize = parseInt(document.getElementById('descSize').value);
            const titleColor = document.getElementById('titleColor').value;
            const descColor = document.getElementById('descColor').value;
            const gradientType = document.getElementById('gradientType').value;
            const brightness = parseInt(document.getElementById('brightness').value);
            const contrast = parseInt(document.getElementById('contrast').value);
            const saturation = parseInt(document.getElementById('saturation').value);

            // Clear canvas
            ctx.fillStyle = bgColor;
            ctx.fillRect(0, 0, width, height);

            // Apply gradient if selected
            if (gradientType !== 'none') {
                let gradient;
                const gradColor1 = document.getElementById('gradColor1').value;
                const gradColor2 = document.getElementById('gradColor2').value;

                if (gradientType === 'linear-h') {
                    gradient = ctx.createLinearGradient(0, 0, width, 0);
                } else if (gradientType === 'linear-v') {
                    gradient = ctx.createLinearGradient(0, 0, 0, height);
                } else if (gradientType === 'diagonal') {
                    gradient = ctx.createLinearGradient(0, 0, width, height);
                } else if (gradientType === 'radial') {
                    gradient = ctx.createRadialGradient(width/2, height/2, 0, width/2, height/2, Math.max(width, height)/2);
                }

                gradient.addColorStop(0, gradColor1);
                gradient.addColorStop(1, gradColor2);
                ctx.fillStyle = gradient;
                ctx.fillRect(0, 0, width, height);
            }

            // Draw background image if loaded
            if (backgroundImage) {
                ctx.globalAlpha = 0.7;
                ctx.drawImage(backgroundImage, 0, 0, width, height);
                ctx.globalAlpha = 1.0;
            }

            // Apply filters
            ctx.filter = `brightness(${brightness}%) contrast(${contrast}%) saturate(${saturation}%)`;

            // Draw shadow if enabled
            if (document.getElementById('shadowToggle').checked) {
                ctx.shadowColor = 'rgba(0, 0, 0, 0.5)';
                ctx.shadowBlur = 15;
                ctx.shadowOffsetX = 3;
                ctx.shadowOffsetY = 3;
            }

            // Draw title
            ctx.fillStyle = titleColor;
            ctx.font = `bold ${titleSize}px ${currentFont}`;
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            
            if (activeEffects.includes('outline')) {
                ctx.strokeStyle = titleColor;
                ctx.lineWidth = 3;
                ctx.strokeText(titleText, width / 2, height / 2 - 50);
            }
            
            if (activeEffects.includes('3d')) {
                for (let i = 5; i > 0; i--) {
                    ctx.fillStyle = changeOpacity(titleColor, 0.3);
                    ctx.fillText(titleText, width / 2 + i, height / 2 - 50 + i);
                }
                ctx.fillStyle = titleColor;
            }

            ctx.fillText(titleText, width / 2, height / 2 - 50);

            // Reset shadow
            ctx.shadowColor = 'transparent';
            ctx.shadowBlur = 0;
            ctx.shadowOffsetX = 0;
            ctx.shadowOffsetY = 0;

            // Draw description
            ctx.fillStyle = descColor;
            ctx.font = `${descSize}px ${currentFont}`;
            wrapText(ctx, descText, width / 2, height / 2 + 50, width - 40, descSize + 10);

            ctx.filter = 'none';
        }

        function wrapText(context, text, x, y, maxWidth, lineHeight) {
            const words = text.split(' ');
            let line = '';
            let lineNumber = 0;

            for (let n = 0; n < words.length; n++) {
                const testLine = line + words[n] + ' ';
                const metrics = context.measureText(testLine);
                const testWidth = metrics.width;

                if (testWidth > maxWidth && n > 0) {
                    context.fillText(line, x, y + lineNumber * lineHeight);
                    line = words[n] + ' ';
                    lineNumber++;
                } else {
                    line = testLine;
                }
            }
            context.fillText(line, x, y + lineNumber * lineHeight);
        }

        function changeFontFamily(font) {
            currentFont = font;
            document.querySelectorAll('.font-option').forEach(el => el.classList.remove('selected'));
            event.target.classList.add('selected');
            updateCanvas();
        }

        function loadBackgroundImage() {
            const file = document.getElementById('bgImage').files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = new Image();
                    img.onload = () => {
                        backgroundImage = img;
                        updateCanvas();
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        }

        function applyEffect(effect) {
            if (activeEffects.includes(effect)) {
                activeEffects = activeEffects.filter(e => e !== effect);
            } else {
                activeEffects.push(effect);
            }
            updateEffectsList();
            updateCanvas();
        }

        function updateEffectsList() {
            const list = document.getElementById('effectsList');
            if (activeEffects.length === 0) {
                list.textContent = 'کوئی اثر منتخب نہیں';
            } else {
                list.textContent = activeEffects.map(e => {
                    const labels = {
                        'bold': '🔤 Bold',
                        'italic': '𝘐 Italic',
                        'outline': '⊕ Outline',
                        'shadow': '⬡ Shadow',
                        'neon': '💫 Neon',
                        '3d': '3️⃣ 3D'
                    };
                    return labels[e];
                }).join(', ');
            }
        }

        function addShape(shape) {
            showStatus(`${shape} شامل کیا گیا | ${shape} added to canvas`);
        }

        function downloadImage() {
            const link = document.createElement('a');
            link.href = canvas.toDataURL('image/png');
            link.download = `social-post-${Date.now()}.png`;
            link.click();
            showStatus('تصویر ڈاؤن لوڈ ہو رہی ہے | Image downloading... ✅');
        }

        function resetDesign() {
            document.getElementById('titleInput').value = 'Your Amazing Title';
            document.getElementById('descInput').value = 'Add your description here for more impact and engagement!';
            document.getElementById('titleSize').value = '48';
            document.getElementById('descSize').value = '20';
            document.getElementById('titleColor').value = '#ffffff';
            document.getElementById('descColor').value = '#ffffff';
            document.getElementById('bgColor').value = '#667eea';
            document.getElementById('gradientType').value = 'none';
            document.getElementById('brightness').value = '100';
            document.getElementById('contrast').value = '100';
            document.getElementById('saturation').value = '100';
            activeEffects = [];
            updateEffectsList();
            updateCanvas();
            showStatus('ڈیزائن دوبارہ شروع کر دیا گیا | Design reset! 🔄');
        }

        function showStatus(message) {
            const statusBar = document.getElementById('statusBar');
            statusBar.textContent = message;
            setTimeout(() => {
                statusBar.textContent = 'تیار ہے | Ready to create amazing posts! 🎨';
            }, 3000);
        }

        function changeOpacity(color, opacity) {
            const r = parseInt(color.slice(1, 3), 16);
            const g = parseInt(color.slice(3, 5), 16);
            const b = parseInt(color.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${opacity})`;
        }

        // Update slider displays
        document.getElementById('titleSize').addEventListener('input', (e) => {
            document.getElementById('titleSizeValue').textContent = e.target.value;
        });
        document.getElementById('descSize').addEventListener('input', (e) => {
            document.getElementById('descSizeValue').textContent = e.target.value;
        });
        document.getElementById('brightness').addEventListener('input', (e) => {
            document.getElementById('brightnessValue').textContent = e.target.value;
        });
        document.getElementById('contrast').addEventListener('input', (e) => {
            document.getElementById('contrastValue').textContent = e.target.value;
        });
        document.getElementById('saturation').addEventListener('input', (e) => {
            document.getElementById('saturationValue').textContent = e.target.value;
        });

        // Initialize
        updateCanvas();
    </script>
</body>
</html>
